{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LOA Tracker",
  "version": "1.1.3",
  "identifier": "xyz.vaanyar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "LOATracker",
        "width": 1350,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ]
  },

  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyOTE0ODU2MDBDMkM5RTcKUldUbnljSUFWa2lSa2p6U2pacFlVRkZYVDZzZm93d0t2MmVTSHcxdWZVWFdPcmxud1hQNGdwU3UK",
      "endpoints": ["https://raw.githubusercontent.com/nobodyeuw/MeowGang/main/latest.json"]
    },

    "webview": {
      "webviewInstallMode": "none"
    }
  }
}
